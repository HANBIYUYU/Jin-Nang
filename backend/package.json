{
  "name": "jin-nang-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute jin-nang-db --local --file=schema.sql",
    "db:seed": "wrangler d1 execute jin-nang-db --local --file=seed.sql",
    "db:migrate:prod": "wrangler d1 execute jin-nang-db --file=schema.sql",
    "db:seed:prod": "wrangler d1 execute jin-nang-db --file=seed.sql"
  },
  "dependencies": {
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250515.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.13.2"
  }
}
